   3.968745600140604*^9}, {3.968745649988371*^9, 3.9687456966423855`*^9}, {
   3.9687458414443703`*^9, 3.9687458446658516`*^9}, {3.968745927677372*^9, 
   3.968745962364893*^9}, {3.9687460495695972`*^9, 3.9687460510533276`*^9}, 
