Cell[TextData[{
 StyleBox["Multi-Cluster Analysis and Size Distribution", "Section"],
 "\n\n",
 StyleBox["Cluster Counting and Statistics", "Subsection"],
 "\nPhysical systems analysis focuses on the distribution of all cluster \
sizes, not just a single central one. Determining the percolation threshold (",
 StyleBox["pc",
  FontSlant->"Italic"],
 ") involves measuring the count and size of clusters.\n\n",
 StyleBox["Iterative Cluster Identification", "Subsection"],
 "\nThe logic is refined to analyze the entire grid:\n1. ",
 StyleBox["Iterative Search",
  FontWeight->"Bold"],
 ": A cluster grows from a random seed.\n2. ",
 StyleBox["Archiving",
  FontWeight->"Bold"],
 ": When growth stops (",
 StyleBox["If[newState == prevState]", "Code"],
 "), the size is recorded in ",
 StyleBox["clusterSize", "Code"],
 ".\n3. ",
 StyleBox["State Change",
  FontWeight->"Bold"],
 ": The finished cluster is marked with a new value (e.g., -5, rendered in \
Red) to prevent recounting.\n4. ",
 StyleBox["Re-seeding",
  FontWeight->"Bold"],
 ": A new, unvisited occupied site (",
 StyleBox["Position[..., 0]", "Code"],
 ") is found, and the process repeats.\nThis loop continues until all \
occupied sites are assigned to a cluster, allowing for the construction of a \
histogram of cluster sizes."
}], "Text",
 CellChangeTimes->{3.9769614847280216`*^9, 
  3.976961518627659*^9},ExpressionUUID->"0cdc55e4-59ef-5741-a125-\
18a260376f44"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"clusterSize", "=", 
    RowBox[{"{", "}"}]}], ";"}], "   ", 
  RowBox[{"(*", 
   RowBox[{
   "list", " ", "to", " ", "plot", " ", "the", " ", "histogram", " ", "of", " ",
     "the", " ", "size", " ", "of", " ", "the", " ", "clusters"}], "*)"}], 
  "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "single", " ", "step", " ", "that", " ", "fill", " ", "the", " ", 
    "nearest", " ", "neighbours"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"PercolationStep2", "[", 
     RowBox[{"n_", ",", "p_", ",", "prevState_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"newState", ",", "tmp"}], "}"}], ",", 
      RowBox[{
       RowBox[{"newState", "=", "prevState"}], ";", "\[IndentingNewLine]", 
       RowBox[{"tmp", "=", 
        RowBox[{"prevState", "+", 
         RowBox[{"RotateLeft", "[", 
          RowBox[{"prevState", ",", 
           RowBox[{"{", 
            RowBox[{"1", ",", "0"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"newState", "=", 
        RowBox[{"ReplacePart", "[", 
         RowBox[{"newState", ",", 
          RowBox[{"Thread", "[", 
           RowBox[{
            RowBox[{"Position", "[", 
             RowBox[{"tmp", ",", "1"}], "]"}], "->", "1"}], "]"}]}], "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"tmp", "=", 
        RowBox[{"prevState", "+", 
         RowBox[{"RotateRight", "[", 
          RowBox[{"prevState", ",", 
           RowBox[{"{", 
            RowBox[{"1", ",", "0"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"newState", "=", 
        RowBox[{"ReplacePart", "[", 
         RowBox[{"newState", ",", 
          RowBox[{"Thread", "[", 
           RowBox[{
            RowBox[{"Position", "[", 
             RowBox[{"tmp", ",", "1"}], "]"}], "->", "1"}], "]"}]}], "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"tmp", "=", 
        RowBox[{"prevState", "+", 
         RowBox[{"RotateLeft", "[", 
          RowBox[{"prevState", ",", 
           RowBox[{"{", 
            RowBox[{"0", ",", "1"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"newState", "=", 
        RowBox[{"ReplacePart", "[", 
         RowBox[{"newState", ",", 
          RowBox[{"Thread", "[", 
           RowBox[{
            RowBox[{"Position", "[", 
             RowBox[{"tmp", ",", "1"}], "]"}], "->", "1"}], "]"}]}], "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"tmp", "=", 
        RowBox[{"prevState", "+", 
         RowBox[{"RotateRight", "[", 
          RowBox[{"prevState", ",", 
           RowBox[{"{", 
            RowBox[{"0", ",", "1"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"newState", "=", 
        RowBox[{"ReplacePart", "[", 
         RowBox[{"newState", ",", 
          RowBox[{"Thread", "[", 
           RowBox[{
            RowBox[{"Position", "[", 
             RowBox[{"tmp", ",", "1"}], "]"}], "->", "1"}], "]"}]}], "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"newState", "==", "prevState"}], ",", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Count", "[", 
              RowBox[{
               RowBox[{"Flatten", "[", "newState", "]"}], ",", "1"}], "]"}], "!=",
              "0"}], ",", 
            RowBox[{"clusterSize", "=", 
             RowBox[{"Append", "[", 
              RowBox[{"clusterSize", ",", 
               RowBox[{"Count", "[", 
                RowBox[{
                 RowBox[{"Flatten", "[", "newState", "]"}], ",", "1"}], 
                "]"}]}], "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"newState", "=", 
           RowBox[{"ReplacePart", "[", 
            RowBox[{"newState", ",", 
             RowBox[{"Thread", "[", 
              RowBox[{
               RowBox[{"Position", "[", 
                RowBox[{"newState", ",", "1"}], "]"}], "->", 
               RowBox[{"-", "5"}]}], "]"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"MemberQ", "[", 
             RowBox[{
              RowBox[{"Flatten", "[", "newState", "]"}], ",", "0"}], "]"}], ",", 
            RowBox[{"newState", "=", 
             RowBox[{"ReplacePart", "[", 
              RowBox[{"newState", ",", 
               RowBox[{
                RowBox[{"RandomChoice", "[", 
                 RowBox[{"Position", "[", 
                  RowBox[{"newState", ",", "0"}], "]"}], "]"}], "->", "1"}]}],
               "]"}]}]}], "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
       "newState"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
   "function", " ", "that", " ", "create", " ", "the", " ", "list", " ", "of",
     " ", "configurations", " ", "for", " ", "different", " ", "time", " ", 
    "step"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"PercolationEvolution2", "[", 
     RowBox[{"n_", ",", "p_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"PercolationEvolution2", "[", 
      RowBox[{"n", ",", "p"}], "]"}], "=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"initialState", ",", "evolution"}], "}"}], ",", 
       RowBox[{
        RowBox[{"initialState", "=", 
         RowBox[{"RandomChoice", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{"p", ",", 
              RowBox[{"1", "-", "p"}]}], "}"}], "->", 
            RowBox[{"{", 
             RowBox[{"0", ",", 
              RowBox[{"-", "10"}]}], "}"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"n", ",", "n"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"initialState", "=", 
         RowBox[{"ArrayPad", "[", 
          RowBox[{"initialState", ",", "1", ",", 
           RowBox[{"-", "10"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"clusterSize", "=", 
         RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"MemberQ", "[", 
           RowBox[{
            RowBox[{"Flatten", "[", "initialState", "]"}], ",", "0"}], "]"}], 
          ",", 
          RowBox[{"initialState", "=", 
           RowBox[{"ReplacePart", "[", 
            RowBox[{"initialState", ",", 
             RowBox[{
              RowBox[{"RandomChoice", "[", 
               RowBox[{"Position", "[", 
                RowBox[{"initialState", ",", "0"}], "]"}], "]"}], "->", 
              "1"}]}], "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"evolution", "=", 
         RowBox[{"NestWhileList", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"PercolationStep2", "[", 
             RowBox[{"n", ",", "p", ",", "#"}], "]"}], "&"}], ",", 
           "initialState", ",", 
           RowBox[{
            RowBox[{"#1", "!=", "#2"}], "&"}], ",", "2"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "evolution"}]}], "]"}]}]}], ";"}], 
