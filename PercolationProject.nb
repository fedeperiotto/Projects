          "<>", "\"\< | Occupied sites: \>\"", "<>", 
          RowBox[{"ToString", "[", 
           RowBox[{"Count", "[", 
            RowBox[{"state", ",", "1", ",", "2"}], "]"}], "]"}]}], ",", 
         "14"}], "]"}]}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Manipulate", " ", "that", " ", "allows", " ", "visualizing", " ", 
