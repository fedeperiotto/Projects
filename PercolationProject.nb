Cell[TextData[{
 StyleBox["Single Cluster Evolution", "Section"],
 "\n\n",
 StyleBox["The Propagation Algorithm", "Subsection"],
 "\nStarting from a seed site, nearest neighbors (Up, Down, Left, Right) are \
iteratively checked. If a neighbor is occupied, it joins the active cluster.\n\
\n\[FilledSmallCircle] ",
 StyleBox["PercolationStep", "Code"],
 ": Performs one iteration of growth. ",
 StyleBox["RotateLeft", "Code"],
 " and ",
 StyleBox["RotateRight", "Code"],
 " efficiently shift the matrix to compare neighbors, identifying and \
activating neighbors of \[OpenCurlyDoubleQuote]active\[CloseCurlyDoubleQuote] \
cells (state 1).\n\[FilledSmallCircle] ",
 StyleBox["PercolationEvolution", "Code"],
 ": Sets up the simulation. A single active site is seeded in the center. ",
 StyleBox["NestWhileList", "Code"],
 " repeatedly applies the step function until the grid stops changing, \
indicating the cluster has reached maximum extent.\n\[FilledSmallCircle] ",
 StyleBox["Visualization",
  FontWeight->"Bold"],
 ": An animation shows the time-evolution of a single cluster growing \
outwards."
}], "Text",
 CellChangeTimes->{{3.96959286868758*^9, 3.969592869102022*^9}, {
  3.9698562196616096`*^9, 3.9698562508051224`*^9}, {3.976961364773428*^9, 
  3.9769614080398407`*^9}},ExpressionUUID->"1b4cd65a-6228-3a47-bb2d-\
a0c56db0bbf5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "single", " ", "step", " ", "that", " ", "fill", " ", "the", " ", 
    "nearest", " ", "neighbours"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"PercolationStep", "[", 
     RowBox[{"n_", ",", "p_", ",", "prevState_"}], "]"}], ":=", 
    "\[IndentingNewLine]", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "newState", "}"}], ",", 
      RowBox[{
       RowBox[{"newState", "=", "prevState"}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"newState", "=", "prevState"}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"tmp", "=", 
        RowBox[{"prevState", "+", 
         RowBox[{"RotateLeft", "[", 
          RowBox[{"prevState", ",", 
           RowBox[{"{", 
            RowBox[{"1", ",", "0"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"newState", "=", 
        RowBox[{"ReplacePart", "[", 
         RowBox[{"newState", ",", 
          RowBox[{"Thread", "[", 
           RowBox[{
            RowBox[{"Position", "[", 
             RowBox[{"tmp", ",", "1"}], "]"}], "->", "1"}], "]"}]}], "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"tmp", "=", 
        RowBox[{"prevState", "+", 
         RowBox[{"RotateRight", "[", 
          RowBox[{"prevState", ",", 
           RowBox[{"{", 
            RowBox[{"1", ",", "0"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"newState", "=", 
        RowBox[{"ReplacePart", "[", 
         RowBox[{"newState", ",", 
          RowBox[{"Thread", "[", 
           RowBox[{
            RowBox[{"Position", "[", 
             RowBox[{"tmp", ",", "1"}], "]"}], "->", "1"}], "]"}]}], "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"tmp", "=", 
        RowBox[{"prevState", "+", 
         RowBox[{"RotateLeft", "[", 
          RowBox[{"prevState", ",", 
           RowBox[{"{", 
            RowBox[{"0", ",", "1"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"newState", "=", 
        RowBox[{"ReplacePart", "[", 
         RowBox[{"newState", ",", 
          RowBox[{"Thread", "[", 
           RowBox[{
            RowBox[{"Position", "[", 
             RowBox[{"tmp", ",", "1"}], "]"}], "->", "1"}], "]"}]}], "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"tmp", "=", 
        RowBox[{"prevState", "+", 
         RowBox[{"RotateRight", "[", 
          RowBox[{"prevState", ",", 
           RowBox[{"{", 
            RowBox[{"0", ",", "1"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"newState", "=", 
        RowBox[{"ReplacePart", "[", 
         RowBox[{"newState", ",", 
          RowBox[{"Thread", "[", 
           RowBox[{
            RowBox[{"Position", "[", 
             RowBox[{"tmp", ",", "1"}], "]"}], "->", "1"}], "]"}]}], "]"}]}], 
       ";", "\[IndentingNewLine]", "newState"}]}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "function", " ", "that", " ", "create", " ", "the", " ", "list", " ", 
     "of", " ", "configurations", " ", "for", " ", "different", " ", "time", " ",
      "step"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"PercolationEvolution", "[", 
     RowBox[{"n_", ",", "p_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"initialState", ",", "center", ",", "evolution"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"initialState", "=", 
        RowBox[{"RandomChoice", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"p", ",", 
             RowBox[{"1", "-", "p"}]}], "}"}], "->", 
           RowBox[{"{", 
            RowBox[{"0", ",", 
             RowBox[{"-", "10"}]}], "}"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "n"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"initialState", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"Ceiling", "[", 
            RowBox[{"n", "/", "2"}], "]"}], ",", 
           RowBox[{"Ceiling", "[", 
            RowBox[{"n", "/", "2"}], "]"}]}], "]"}], "]"}], "=", "1"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"initialState", "=", 
        RowBox[{"ArrayPad", "[", 
         RowBox[{"initialState", ",", "1", ",", 
          RowBox[{"-", "10"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"evolution", "=", 
        RowBox[{"NestWhileList", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"PercolationStep", "[", 
            RowBox[{"n", ",", "p", ",", "#"}], "]"}], "&"}], ",", 
          "initialState", ",", 
          RowBox[{
           RowBox[{"#1", "!=", "#2"}], "&"}], ",", "2"}], "]"}]}], ";", 
       "\[IndentingNewLine]", "evolution"}]}], "]"}]}], "\[IndentingNewLine]",
    "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
